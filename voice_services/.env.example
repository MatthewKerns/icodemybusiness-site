# Voice Services Environment Configuration
# Copy to .env and fill in your values

# Vapi Configuration
VAPI_API_KEY=vapi_xxxxxxxxxxxxxxxxxx
VAPI_WEBHOOK_SECRET=your-webhook-secret

# Convex Database
CONVEX_URL=https://your-app.convex.cloud
CONVEX_DEPLOY_URL=https://your-app.convex.site

# Phone Numbers
TRANSFER_PHONE_NUMBER=+14155555678  # Matthew's phone
VOICE_AGENT_NUMBER=+14155551234     # Your Vapi number

# Optional: Monitoring
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Development Settings
DEBUG=false
LOG_LEVEL=INFO